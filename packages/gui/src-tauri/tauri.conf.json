{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri/refs/heads/v2/crates/tauri-cli/schema.json",
  "productName": "Journey",
  "version": "0.0.0",
  "identifier": "dev.journey.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "pnpm --filter @usejourney/gui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Journey",
        "width": 1600,
        "height": 1000,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
